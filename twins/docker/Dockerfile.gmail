# ---------------------------------------------------------------------------
# Stage 1 -- Builder
# ---------------------------------------------------------------------------
FROM rust:1.86-bookworm AS builder

WORKDIR /usr/src/app

# Copy the entire workspace (context = repo root)
COPY Cargo.toml Cargo.lock* ./
COPY crates/ crates/
COPY apps/ apps/

# Build the twin-gmail-server binary in release mode
RUN cargo build --release --package twin-gmail-server

# ---------------------------------------------------------------------------
# Stage 2 -- Runtime
# ---------------------------------------------------------------------------
FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Copy the compiled binary from the builder stage
COPY --from=builder /usr/src/app/target/release/twin-gmail-server /usr/local/bin/twin-gmail-server

ENV TWIN_PORT=8080
EXPOSE 8080

ENTRYPOINT ["twin-gmail-server"]
