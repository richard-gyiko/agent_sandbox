{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whizy.dev/labs/v3/assertions/drive.filename_sequence_valid.params.schema.json",
  "type": "object",
  "required": ["parent_path"],
  "properties": {
    "parent_path": { "type": "string", "minLength": 1 },
    "filename_regex": { "type": "string", "minLength": 1 },
    "min_matches": { "type": "integer", "minimum": 1 },
    "require_unique_per_day": { "type": "boolean" },
    "require_gapless_per_day": { "type": "boolean" }
  },
  "additionalProperties": false
}
