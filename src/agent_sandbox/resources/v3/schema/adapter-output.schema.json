{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whizy.dev/labs/v3/adapter-output.schema.json",
  "type": "object",
  "required": ["schema_version", "status", "result"],
  "properties": {
    "schema_version": { "type": "string", "const": "lab.adapter.v1" },
    "status": {
      "type": "string",
      "enum": ["COMPLETED", "FAILED", "TIMEOUT", "CANCELLED"]
    },
    "result": { "type": "object" },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "enum": ["FAILED", "TIMEOUT", "CANCELLED"] }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["error"]
      }
    }
  ],
  "additionalProperties": true
}
