{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-sandbox.dev/schema/v3/http_protocols/generic-json.config.schema.json",
  "type": "object",
  "required": ["url"],
  "properties": {
    "url": { "type": "string", "minLength": 1 },
    "method": { "type": "string", "enum": ["POST", "PUT"] },
    "headers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "protocol": { "type": "string", "const": "generic-json" }
  },
  "additionalProperties": true
}
