{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whizy.dev/labs/v3/adapter-input.schema.json",
  "type": "object",
  "required": ["schema_version", "run", "scenario", "runtime", "input"],
  "properties": {
    "schema_version": { "type": "string", "const": "lab.adapter.v1" },
    "run": {
      "type": "object",
      "required": ["id", "mode", "target"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["workflow", "agent"] },
        "target": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "scenario": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "required": ["env", "session_state"],
      "properties": {
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "session_state": { "type": "object" }
      },
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "properties": {
        "text": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
